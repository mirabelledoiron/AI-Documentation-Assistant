# backend/.env.example
PORT=8080
ENVIRONMENT=development
DATABASE_URL=postgres://admin:secretpassword@localhost:5432/docs_db?sslmode=disable
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Optional: change the GitHub repo used for seeding/sync
SEED_GITHUB_OWNER=mirabelledoiron
SEED_GITHUB_REPO=Atelier-Design-System
SEED_GITHUB_REF=main
SEED_GITHUB_LIMIT=200
SEED_AUTO_ON_START=true
JWT_SECRET=your_jwt_secret_key_here
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info
